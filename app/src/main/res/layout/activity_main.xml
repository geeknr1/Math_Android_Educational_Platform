<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:orientation="vertical"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:background="@drawable/digitsmath">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="40dp"
            app:cardCornerRadius="40dp"
            app:cardElevation="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_gravity="center_horizontal"
                android:padding="24dp"
                android:background="@drawable/lavender_border">

                <ImageView
                    android:id="@+id/welcomeMessage"
                    android:gravity="center_horizontal"
                    android:layout_width="250dp"
                    android:layout_height="150dp"
                    android:src="@drawable/mathstuffimg" />

                <ImageButton
                    android:id="@+id/appguide"
                    android:layout_width="220dp"
                    android:layout_height="100dp"
                    android:scaleType="fitXY"
                    android:background="@color/red"
                    android:layout_marginBottom="0dp"
                    android:layout_marginTop="20dp"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:src="@drawable/appguide"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <ImageButton
                    android:id="@+id/Tutorial"
                    android:layout_width="220dp"
                    android:layout_height="100dp"
                    android:scaleType="fitXY"
                    android:layout_marginBottom="20dp"
                    android:layout_marginTop="20dp"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:src="@drawable/tutorial"
                    android:background="@drawable/rounded_button"
                    android:textSize="25sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    tools:layout_editor_absoluteY="358dp"/>

                <ImageButton
                    android:id="@+id/Games"
                    android:layout_width="220dp"
                    android:layout_height="100dp"
                    android:layout_marginBottom="20dp"
                    android:layout_marginTop="0dp"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:src="@drawable/games"
                    android:scaleType="fitXY"
                    android:background="@drawable/rounded_button"
                    android:textSize="35sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    tools:layout_editor_absoluteY="358dp"/>

                <ImageButton
                    android:id="@+id/Quit"
                    android:layout_width="150dp"
                    android:layout_height="50dp"
                    android:layout_marginBottom="20dp"
                    android:layout_marginTop="40dp"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:src="@drawable/quit"
                    android:scaleType="fitXY"
                    android:background="@drawable/rounded_button_3"
                    android:textSize="50sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>



    </LinearLayout>

    <include layout="@layout/include_notification_bell" />

</FrameLayout>