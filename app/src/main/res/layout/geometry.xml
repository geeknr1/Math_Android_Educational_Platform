<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:fillViewport="true"
        android:background="@drawable/mathgeom"
        tools:context=".Geometry">

        <LinearLayout
            android:id="@+id/mainPage"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="25dp"
                app:cardCornerRadius="30dp"
                app:cardElevation="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_gravity="center_horizontal"
                    android:padding="24dp"
                    android:background="@drawable/lavender_border">

                    <TextView
                        android:id="@+id/welcome"
                        android:gravity="center_horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:textSize="25sp"
                        android:text="WELCOME TO GEOMETRY" />

                    <TextView
                        android:id="@+id/chapter"
                        android:gravity="center_horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="20sp"
                        android:paddingTop="16dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="CHOOSE YOUR CHAPTER"
                        />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Spinner
                android:background="#ADD8E6"
                android:id="@+id/spinnerChapter1Geo"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:spinnerMode="dropdown"
                android:layout_marginBottom="20dp"
                android:layout_marginTop="20dp"
                android:text=" Fundamental Concepts of Geometry and
Geometric Figures"
                />

            <Spinner
                android:background="#ADD8E6"
                android:id="@+id/spinnerChapter2Geo"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:spinnerMode="dropdown"
                android:layout_marginBottom="20dp"
                android:layout_marginTop="20dp"
                android:text="Straight Lines"/>

            <Spinner
                android:background="#ADD8E6"
                android:id="@+id/spinnerChapter3Geo"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:spinnerMode="dropdown"
                android:layout_marginBottom="20dp"
                android:layout_marginTop="20dp"
                android:text="Circles"/>

            <Spinner
                android:background="#ADD8E6"
                android:id="@+id/spinnerChapter4Geo"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:spinnerMode="dropdown"
                android:layout_marginBottom="20dp"
                android:layout_marginTop="20dp"
                android:text=" Similarity of Polygons"/>

            <Spinner
                android:background="#ADD8E6"
                android:id="@+id/spinnerChapter5Geo"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:spinnerMode="dropdown"
                android:layout_marginBottom="20dp"
                android:layout_marginTop="20dp"
                android:text="Transformation of Figures"/>

            <Spinner
                android:background="#ADD8E6"
                android:id="@+id/spinnerChapter6Geo"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:spinnerMode="dropdown"
                android:layout_marginBottom="20dp"
                android:layout_marginTop="20dp"
                android:text=" Vectors in the Plane and Trigonometric Functions of the Angle"/>

            <Spinner
                android:background="#ADD8E6"
                android:id="@+id/spinnerChapter7Geo"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:spinnerMode="dropdown"
                android:layout_marginBottom="20dp"
                android:layout_marginTop="20dp"
                android:text="Areas of Polygons"/>

            <Spinner
                android:background="#ADD8E6"
                android:id="@+id/spinnerChapter8Geo"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:spinnerMode="dropdown"
                android:layout_marginBottom="20dp"
                android:layout_marginTop="20dp"
                android:text="Regular Polygons. Length of Circumference.
Area of a Circle"/>

            <Spinner
                android:background="#ADD8E6"
                android:id="@+id/spinnerChapter9Geo"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:spinnerMode="dropdown"
                android:layout_marginBottom="20dp"
                android:layout_marginTop="20dp"
                android:text="Fundamentals of Solid Geometry"/>

            <ImageButton
                android:id="@+id/backToTutorial_2"
                android:layout_width="150dp"
                android:layout_height="50dp"
                android:layout_marginBottom="20dp"
                android:layout_marginTop="20dp"
                android:layout_gravity="center"
                android:src="@drawable/back"
                android:scaleType="fitXY"
                android:backgroundTint="#ff0000"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/white"/>


        </LinearLayout>

    </ScrollView>

    <include layout="@layout/include_notification_bell" />

</FrameLayout>