    <string name="SectionThreeTheoryDef_2">Definitions:\n
• Significant Digits: all digits known with certainty, plus one doubtful digit.\n
• For decimals, count from first non-zero digit.\n
• For whole numbers, zeros at the end may or may not be significant.\n
• Correct Digits: digits that stay within half a unit of their place value.</string>
    <string name="SectionThreeTheoryDefQuestion_2">How many significant digits does 0.00470 have?</string>
    <string name="SectionThreeTheoryDefAnswerOne_2">2</string>
    <string name="SectionThreeTheoryDefAnswerTwo_2">3</string>
    <string name="SectionThreeTheoryDefAnswerThree_2">5</string>
    <string name="SectionThreeTheoryDefCorrectAnswer_2">3</string>

    <string name="SectionThreeTheoryProperties_2">Properties:\n
• Rounding Rules:\n
1. If first discarded digit &lt; 5, leave unchanged.\n
2. If &gt; 5, increase last kept digit by 1.\n
3. If exactly 5 followed by zeros, round to even.\n
• Scientific Notation: numbers written as a·10ⁿ with 1 ≤ a &lt; 10 to show correct digits clearly.</string>
    <string name="SectionThreeTheoryPropsQuestion_2">Round 3.7851 to 2 decimal places. What is the result?</string>
    <string name="SectionThreeTheoryPropsAnswerOne_2">3.78</string>
    <string name="SectionThreeTheoryPropsAnswerTwo_2">3.79</string>
    <string name="SectionThreeTheoryPropsAnswerThree_2">3.80</string>
    <string name="SectionThreeTheoryPropsCorrectAnswer_2">3.79</string>

    <string name="SectionThreeTheoryWorkedExamples_2">Write 0.000 582 in scientific notation with 3 significant digits.\n
Step 1: Move decimal: 5.82 × 10⁻⁴.\n
Step 2: Count digits: 5, 8, 2 — all 3 are significant.\n
Step 3: Result: 5.82 × 10⁻⁴.</string>
    <string name="SectionThreeTheoryWorkedExQuestion_2">What is 0.000582 written in scientific notation (3 significant digits)?</string>
    <string name="SectionThreeTheoryWorkedExAnswerOne_2">5.8 × 10⁻⁴</string>
    <string name="SectionThreeTheoryWorkedExAnswerTwo_2">5.82 × 10⁻³</string>
    <string name="SectionThreeTheoryWorkedExAnswerThree_2">5.82 × 10⁻⁴</string>
    <string name="SectionThreeTheoryWorkedExCorrectAnswer_2">5.82 × 10⁻⁴</string>

