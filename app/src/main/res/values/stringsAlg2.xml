    <string name="SectionFiveTheoryWorkedExAnswerTwo_2">0.41</string>
    <string name="SectionFiveTheoryWorkedExAnswerThree_2">0.80</string>
    <string name="SectionFiveTheoryWorkedExCorrectAnswer_2">0.41</string>

