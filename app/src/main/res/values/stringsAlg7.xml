    <!-- ===================== SECTION FOUR: Problems on Progressions ===================== -->
    <string name="SectionFourTheoryDef_7">Problems on Progressions: apply arithmetic and geometric formulas to solve number problems.</string>
    <string name="SectionFourTheoryDefQuestion_7">Insert 3 arithmetic means between 7 and 19. What is the common difference d?</string>
    <string name="SectionFourTheoryDefAnswerOne_7">2</string>
    <string name="SectionFourTheoryDefAnswerTwo_7">3</string>
    <string name="SectionFourTheoryDefAnswerThree_7">4</string>
    <string name="SectionFourTheoryDefCorrectAnswer_7">3</string>

    <string name="SectionFourTheoryProperties_7">Dual-nature: only equal terms (q=1). Insert arithmetic means: e.g., 7 through 19 → d=(19−7)/4=4 → 7,7,11,15,19. Natural sums: e.g., 2-digit numbers sum=4905. Insert geometric means: 1 through 256 → q=4 → 1,1*4,4*4,16*4,64*4. Sequence change: G.P. may become A.P. if term adjusted.</string>
    <string name="SectionFourTheoryPropsQuestion_7">Insert 2 geometric means between 2 and 54. What is the common ratio q?</string>
    <string name="SectionFourTheoryPropsAnswerOne_7">2</string>
    <string name="SectionFourTheoryPropsAnswerTwo_7">3</string>
    <string name="SectionFourTheoryPropsAnswerThree_7">4</string>
    <string name="SectionFourTheoryPropsCorrectAnswer_7">3</string>

    <string name="SectionFourTheoryWorkedExamples_7">Example 1: Insert 3 arithmetic means between 2 and 18. d = (18−2)/(3+1) = 4. Sequence: 2, 6, 10, 14, 18. ✓
Example 2: Sum of all 2-digit multiples of 3: first=12, last=99, d=3. n=(99−12)/3+1=30. S = (12+99)·30/2 = 1665. ✓
Example 3: Insert 2 geometric means between 3 and 24. q³=24/3=8 → q=2. Sequence: 3, 6, 12, 24. ✓</string>
    <string name="SectionFourTheoryWorkedExQuestion_7">What is the sum of the first 5 terms of an A.P. with a₁ = 2 and d = 3?</string>
    <string name="SectionFourTheoryWorkedExAnswerOne_7">25</string>
    <string name="SectionFourTheoryWorkedExAnswerTwo_7">30</string>
    <string name="SectionFourTheoryWorkedExAnswerThree_7">35</string>
    <string name="SectionFourTheoryWorkedExCorrectAnswer_7">30</string>

