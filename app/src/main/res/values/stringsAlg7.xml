    <!-- ===================== SECTION FIVE: Logarithms ===================== -->
    <string name="SectionFiveTheoryDef_7">Taking Logarithms and Antilogarithms: simplify algebraic expressions using log laws.</string>
    <string name="SectionFiveTheoryDefQuestion_7">What is log₂(8)?</string>
    <string name="SectionFiveTheoryDefAnswerOne_7">2</string>
    <string name="SectionFiveTheoryDefAnswerTwo_7">3</string>
    <string name="SectionFiveTheoryDefAnswerThree_7">4</string>
    <string name="SectionFiveTheoryDefCorrectAnswer_7">3</string>

    <string name="SectionFiveTheoryProperties_7">logₐ(ab)=logₐa+logₐb. logₐ(a/b)=logₐa−logₐb. logₐ(xᵏ)=k·logₐx. Based on a^(logₐb)=b identity.</string>
    <string name="SectionFiveTheoryPropsQuestion_7">Is log₂(4·8) = log₂(4) + log₂(8)?</string>
    <string name="SectionFiveTheoryPropsAnswerOne_7">True</string>
    <string name="SectionFiveTheoryPropsAnswerTwo_7">False</string>
    <string name="SectionFiveTheoryPropsAnswerThree_7">Neither</string>
    <string name="SectionFiveTheoryPropsCorrectAnswer_7">True</string>

    <string name="SectionFiveWorkedExamples_7">Example 1: Simplify log₂(32). 32 = 2⁵ → log₂(32) = 5. ✓
Example 2: Simplify log₃(27) − log₃(3). = log₃(27/3) = log₃(9) = 2. ✓
Example 3: Simplify log₅(5⁴). = 4·log₅(5) = 4·1 = 4. ✓</string>
    <string name="SectionFiveTheoryWorkedExQuestion_7">What is log₃(81)?</string>
    <string name="SectionFiveTheoryWorkedExAnswerOne_7">3</string>
    <string name="SectionFiveTheoryWorkedExAnswerTwo_7">4</string>
    <string name="SectionFiveTheoryWorkedExAnswerThree_7">5</string>
    <string name="SectionFiveTheoryWorkedExCorrectAnswer_7">4</string>

