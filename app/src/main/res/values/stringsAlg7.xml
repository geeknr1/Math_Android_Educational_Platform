    <!-- ===================== SECTION ONE: Sequences – Definition ===================== -->
    <string name="SectionOneTheoryDef_7">A sequence assigns each natural number n a term aₙ; it\'s a function on ℕ. Terms: a₁, a₂, a₃…</string>
    <string name="SectionOneTheoryDefQuestion_7">If aₙ = 2n, what is a₅?</string>
    <string name="SectionOneTheoryDefAnswerOne_7">8</string>
    <string name="SectionOneTheoryDefAnswerTwo_7">10</string>
    <string name="SectionOneTheoryDefAnswerThree_7">12</string>
    <string name="SectionOneTheoryDefCorrectAnswer_7">10</string>

    <string name="SectionOneTheoryProperties_7">Finite → first n terms; Infinite → all n. Defined by formula aₙ=f(n) or recurrence rule (e.g. Fibonacci: a₁=1,a₂=1,aₙ₊₂=aₙ₊₁+aₙ). Increasing: aₙ₊₁&gt;aₙ; Decreasing: aₙ₊₁&lt;aₙ; Constant → equal terms.</string>
    <string name="SectionOneTheoryPropsQuestion_7">Is the sequence aₙ = n² increasing?</string>
    <string name="SectionOneTheoryPropsAnswerOne_7">True</string>
    <string name="SectionOneTheoryPropsAnswerTwo_7">False</string>
    <string name="SectionOneTheoryPropsAnswerThree_7">Neither</string>
    <string name="SectionOneTheoryPropsCorrectAnswer_7">True</string>

    <string name="SectionOneTheoryWorkedExamples_7">Example 1: aₙ = 3n. First five terms: 3, 6, 9, 12, 15. Increasing sequence. ✓
Example 2: aₙ = 1/n. First five terms: 1, 1/2, 1/3, 1/4, 1/5. Decreasing sequence. ✓
Example 3: Fibonacci: a₁=1, a₂=1, aₙ=aₙ₋₁+aₙ₋₂. Terms: 1, 1, 2, 3, 5, 8, 13… ✓</string>
    <string name="SectionOneTheoryWorkedExQuestion_7">For aₙ = 5n, what is a₄?</string>
    <string name="SectionOneTheoryWorkedExAnswerOne_7">15</string>
    <string name="SectionOneTheoryWorkedExAnswerTwo_7">20</string>
    <string name="SectionOneTheoryWorkedExAnswerThree_7">25</string>
    <string name="SectionOneTheoryWorkedExCorrectAnswer_7">20</string>

