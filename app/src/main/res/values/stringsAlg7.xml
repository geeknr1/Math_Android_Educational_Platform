    <!-- ===================== SECTION THREE: Geometric Progression ===================== -->
    <string name="SectionThreeTheoryDef_7">Geometric progression (G.P.): each term = previous term × constant q.</string>
    <string name="SectionThreeTheoryDefQuestion_7">In a G.P. with a₁ = 2 and q = 3, what is a₄?</string>
    <string name="SectionThreeTheoryDefAnswerOne_7">18</string>
    <string name="SectionThreeTheoryDefAnswerTwo_7">54</string>
    <string name="SectionThreeTheoryDefAnswerThree_7">162</string>
    <string name="SectionThreeTheoryDefCorrectAnswer_7">54</string>

    <string name="SectionThreeTheoryProperties_7">Common ratio q=aₙ₊₁/aₙ. Property: aₙ₊₁=√(aₙaₙ₊₂). nth term: aₙ=a₁qⁿ⁻¹. Sum: Sₙ=a₁(qⁿ−1)/(q−1), q≠1.</string>
    <string name="SectionThreeTheoryPropsQuestion_7">For a G.P. with a₁ = 1 and q = 2, what is S₄?</string>
    <string name="SectionThreeTheoryPropsAnswerOne_7">12</string>
    <string name="SectionThreeTheoryPropsAnswerTwo_7">15</string>
    <string name="SectionThreeTheoryPropsAnswerThree_7">16</string>
    <string name="SectionThreeTheoryPropsCorrectAnswer_7">15</string>

    <string name="SectionThreeTheoryWorkedExamples_7">Example 1: G.P.: a₁=3, q=2. Find a₅. a₅ = 3·2⁴ = 3·16 = 48. ✓
Example 2: G.P.: a₁=1, q=3. Find S₄. S₄ = 1·(3⁴−1)/(3−1) = (81−1)/2 = 40. ✓
Example 3: G.P.: 4, 12, 36… Find q. q = 12/4 = 3. ✓</string>
    <string name="SectionThreeTheoryWorkedExQuestion_7">In a G.P. with a₁ = 5 and q = 2, what is a₃?</string>
    <string name="SectionThreeTheoryWorkedExAnswerOne_7">15</string>
    <string name="SectionThreeTheoryWorkedExAnswerTwo_7">20</string>
    <string name="SectionThreeTheoryWorkedExAnswerThree_7">25</string>
    <string name="SectionThreeTheoryWorkedExCorrectAnswer_7">20</string>

