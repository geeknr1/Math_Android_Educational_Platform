    <!-- ===================== SECTION TWO: Arithmetic Progression ===================== -->
    <string name="SectionTwoTheoryDef_7">Arithmetic progression (A.P.): each term = previous term + constant d.</string>
    <string name="SectionTwoTheoryDefQuestion_7">In an A.P. with a₁ = 3 and d = 4, what is a₄?</string>
    <string name="SectionTwoTheoryDefAnswerOne_7">12</string>
    <string name="SectionTwoTheoryDefAnswerTwo_7">15</string>
    <string name="SectionTwoTheoryDefAnswerThree_7">18</string>
    <string name="SectionTwoTheoryDefCorrectAnswer_7">15</string>

    <string name="SectionTwoTheoryProperties_7">Common difference d=aₙ₊₁−aₙ. Property: aₙ₊₁=(aₙ+aₙ₊₂)/2. nth term: aₙ=a₁+(n−1)d. Sum: Sₙ=(a₁+aₙ)n/2.</string>
    <string name="SectionTwoTheoryPropsQuestion_7">For an A.P. with a₁ = 2 and d = 3, what is the sum S₄?</string>
    <string name="SectionTwoTheoryPropsAnswerOne_7">20</string>
    <string name="SectionTwoTheoryPropsAnswerTwo_7">26</string>
    <string name="SectionTwoTheoryPropsAnswerThree_7">32</string>
    <string name="SectionTwoTheoryPropsCorrectAnswer_7">26</string>

    <string name="SectionTwoTheoryWorkedExamples_7">Example 1: A.P.: a₁=5, d=3. Find a₆. a₆ = 5 + (6−1)·3 = 5 + 15 = 20. ✓
Example 2: A.P.: a₁=2, d=4. Find S₅. a₅ = 2 + 4·4 = 18. S₅ = (2+18)·5/2 = 50. ✓
Example 3: A.P.: 7, 11, 15, 19… Find d. d = 11 − 7 = 4. ✓</string>
    <string name="SectionTwoTheoryWorkedExQuestion_7">In an A.P. with a₁ = 1 and d = 2, what is a₆?</string>
    <string name="SectionTwoTheoryWorkedExAnswerOne_7">9</string>
    <string name="SectionTwoTheoryWorkedExAnswerTwo_7">11</string>
    <string name="SectionTwoTheoryWorkedExAnswerThree_7">13</string>
    <string name="SectionTwoTheoryWorkedExCorrectAnswer_7">11</string>

