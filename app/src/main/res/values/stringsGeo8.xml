    <!--               SECTION TWO: CIRCUMFERENCE & ARC LENGTH           -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <!-- Fixed typo: π ≈ 15.1416 → π ≈ 3.1416 -->
    <string name="SectionTwoTheoryDef_15">• Pi (π) ≈ 3.1416, ratio of circumference to diameter.</string>

    <!-- Q: Pi (π) is the ratio of circumference to which dimension? Answer: 2 (diameter = 2R) -->
    <string name="SectionTwoTheoryDefQuestion_15">Pi (π) is the ratio of the circumference to which measurement of a circle?</string>
    <string name="SectionTwoTheoryDefAnswerOne_15">radius</string>
    <string name="SectionTwoTheoryDefAnswerTwo_15">diameter</string>
    <string name="SectionTwoTheoryDefAnswerThree_15">apothem</string>
    <string name="SectionTwoTheoryDefCorrectAnswer_15">diameter</string>

    <!-- Fixed typo: C=15πR → C=2πR -->
    <string name="SectionTwoTheoryProperties_15">• Circumference ratios = radius or diameter ratios.
\n • C=πD=2πR, where D=diameter of the circle, R=circle radius, C=circle length.
\n • Arc length l=(πR/180°)*n° for central angle n°.</string>

    <!-- Q: A circle has radius R = 7. What is its circumference? Answer: 14π -->
    <string name="SectionTwoTheoryPropsQuestion_15">A circle has radius R = 7. What is its circumference (leave answer in terms of π)?</string>
    <string name="SectionTwoTheoryPropsAnswerOne_15">7π</string>
    <string name="SectionTwoTheoryPropsAnswerTwo_15">14π</string>
    <string name="SectionTwoTheoryPropsAnswerThree_15">49π</string>
    <string name="SectionTwoTheoryPropsCorrectAnswer_15">14π</string>

    <string name="SectionTwoTheoryWorkedExamples_15">• Circle with radius R = 5: circumference C = 2 × π × 5 = 10π ≈ 31.42.
\n • Arc length for central angle 90° with R = 4: l = (π × 4 / 180°) × 90° = (4π / 2) = 2π ≈ 6.28.
\n • Two circles with radii 3 and 6 have circumferences in ratio 3:6 = 1:2, confirming circumference ratios equal radius ratios.</string>

    <!-- Q: Arc length for central angle 90° and R=4? Answer: 2π -->
    <string name="SectionTwoTheoryWorkedExQuestion_15">What is the arc length for a central angle of 90° in a circle with radius R = 4 (leave answer in terms of π)?</string>
    <string name="SectionTwoTheoryWorkedExAnswerOne_15">4π</string>
    <string name="SectionTwoTheoryWorkedExAnswerTwo_15">π</string>
    <string name="SectionTwoTheoryWorkedExAnswerThree_15">2π</string>
    <string name="SectionTwoTheoryWorkedExCorrectAnswer_15">2π</string>

