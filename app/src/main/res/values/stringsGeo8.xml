    <!--                  SECTION ONE: REGULAR POLYGONS                  -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <string name="SectionOneTheoryDef_15">• A regular polygon has equal sides and angles.
\n • Its centre is intersection of inscribed and circumscribed circles.
\n • Apothem = perpendicular to side; radius = centre to vertex.</string>

    <!-- Q: Does a regular polygon have equal sides AND equal angles? Answer: True -->
    <string name="SectionOneTheoryDefQuestion_15">Does a regular polygon have both equal sides and equal angles?</string>
    <string name="SectionOneTheoryDefAnswerOne_15">True</string>
    <string name="SectionOneTheoryDefAnswerTwo_15">False</string>
    <!-- Only 2 answers for True/False — third answer intentionally removed -->
    <string name="SectionOneTheoryDefAnswerThree_15"></string>
    <string name="SectionOneTheoryDefCorrectAnswer_15">True</string>

    <!-- Fixed typo: (n−15) → (n−2) and 15R → 2R -->
    <string name="SectionOneTheoryProperties_15">• Interior angle α=(180°*(n−2))/n.
\n • Inscribed and circumscribed circles share the same centre.
\n • Area = ½ × perimeter × apothem = ½ × n × R² × sin(360°/n).
\n • Side length s=2R*sin(180°/n).</string>

    <!-- Q: What is the interior angle of a regular hexagon (n=6)? Answer: 120 -->
    <string name="SectionOneTheoryPropsQuestion_15">What is the interior angle (in degrees) of a regular hexagon (n = 6)?</string>
    <string name="SectionOneTheoryPropsAnswerOne_15">90</string>
    <string name="SectionOneTheoryPropsAnswerTwo_15">120</string>
    <string name="SectionOneTheoryPropsAnswerThree_15">108</string>
    <string name="SectionOneTheoryPropsCorrectAnswer_15">120</string>

    <string name="SectionOneTheoryWorkedExamples_15">• Regular hexagon with circumscribed radius R = 6: side length s = 2 × 6 × sin(180°/6) = 12 × sin(30°) = 12 × ½ = 6. So in a regular hexagon the side always equals the circumscribed radius.
\n • Interior angle of a regular pentagon (n = 5): α = (180° × (5 − 2)) / 5 = (180° × 3) / 5 = 108°.
\n • Area of a regular hexagon with apothem a = 5 and perimeter P = 60: S = ½ × 60 × 5 = 150.</string>

    <!-- Q: Interior angle of a regular pentagon (n=5)? Answer: 108 -->
    <string name="SectionOneTheoryWorkedExQuestion_15">What is the interior angle (in degrees) of a regular pentagon (n = 5)?</string>
    <string name="SectionOneTheoryWorkedExAnswerOne_15">90</string>
    <string name="SectionOneTheoryWorkedExAnswerTwo_15">72</string>
    <string name="SectionOneTheoryWorkedExAnswerThree_15">108</string>
    <string name="SectionOneTheoryWorkedExCorrectAnswer_15">108</string>

