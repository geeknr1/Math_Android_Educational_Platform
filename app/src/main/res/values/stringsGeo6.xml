    <string name="SectionSixTheoryWorkedExAnswerTwo_13">10</string>
    <string name="SectionSixTheoryWorkedExAnswerThree_13">5</string>
    <string name="SectionSixTheoryWorkedExCorrectAnswer_13">5</string>

