    <!--         SECTION SIX: TRIG FUNCTIONS — RIGHT TRIANGLE            -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <string name="SectionSixTheoryDef_13">• sinα = opposite/hypotenuse.
\n • cosα = adjacent/hypotenuse.
\n • tanα = opposite/adjacent.</string>

    <!-- Q: Does sinα = opposite/hypotenuse in a right triangle? Answer: True -->
    <string name="SectionSixTheoryDefQuestion_13">In a right triangle, does sinα equal opposite divided by hypotenuse?</string>
    <string name="SectionSixTheoryDefAnswerOne_13">True</string>
    <string name="SectionSixTheoryDefAnswerTwo_13">False</string>
    <!-- Only 2 answers for True/False — third answer intentionally removed -->
    <string name="SectionSixTheoryDefAnswerThree_13"></string>
    <string name="SectionSixTheoryDefCorrectAnswer_13">True</string>

    <string name="SectionSixTheoryProperties_13">• sin(90°−α)=cosα, cos(90°−α)=sinα.
\n • sin(180°−α)=sinα, cos(180°−α)=−cosα.
\n • Shows complementary and supplementary relations.</string>

    <!-- Q: What does sin(90°−α) equal? Answer: cosα -->
    <string name="SectionSixTheoryPropsQuestion_13">What does sin(90° − α) equal?</string>
    <string name="SectionSixTheoryPropsAnswerOne_13">−cosα</string>
    <string name="SectionSixTheoryPropsAnswerTwo_13">cosα</string>
    <string name="SectionSixTheoryPropsAnswerThree_13">sinα</string>
    <string name="SectionSixTheoryPropsCorrectAnswer_13">cosα</string>

    <string name="SectionSixTheoryWorkedExamples_13">• In a right triangle with hypotenuse 10 and one angle α = 30°: opposite = 10 × sin(30°) = 10 × ½ = 5; adjacent = 10 × cos(30°) = 10 × (√3/2) = 5√3.
\n • Complementary relation check: sin(60°) = cos(30°) = √3/2 ✓; cos(60°) = sin(30°) = ½ ✓ — the two acute angles of a right triangle always sum to 90°.
\n • Supplementary relation: sin(150°) = sin(180°−30°) = sin(30°) = ½; cos(150°) = −cos(30°) = −√3/2 — used to extend trig ratios beyond 90°.</string>

    <!-- Q: In a right triangle with hypotenuse 10 and α=30°, what is the opposite side? Answer: 5 -->
    <string name="SectionSixTheoryWorkedExQuestion_13">In a right triangle with hypotenuse 10 and angle α = 30°, what is the length of the opposite side?</string>
