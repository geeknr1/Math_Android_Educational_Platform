    <!--              SECTION FIVE: TRIG FUNCTIONS — UNIT CIRCLE         -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <string name="SectionFiveTheoryDef_13">• Sine is the y-coordinate of a unit circle point.
\n • Cosine is the x-coordinate.
\n • Tangent equals sine divided by cosine.</string>

    <!-- Q: Is sine the y-coordinate of a point on the unit circle? Answer: True -->
    <string name="SectionFiveTheoryDefQuestion_13">Is sine defined as the y-coordinate of a point on the unit circle?</string>
    <string name="SectionFiveTheoryDefAnswerOne_13">True</string>
    <string name="SectionFiveTheoryDefAnswerTwo_13">False</string>
    <!-- Only 2 answers for True/False — third answer intentionally removed -->
    <string name="SectionFiveTheoryDefAnswerThree_13"></string>
    <string name="SectionFiveTheoryDefCorrectAnswer_13">True</string>

    <string name="SectionFiveTheoryProperties_13">• Sine is odd; cosine is even.
\n • sin²α+cos²α=1.
\n • 1+tan²α=1/(cos²α).</string>

    <!-- Q: What does sin²α + cos²α equal? Answer: 1 -->
    <string name="SectionFiveTheoryPropsQuestion_13">What is the value of sin²α + cos²α for any angle α?</string>
    <string name="SectionFiveTheoryPropsAnswerOne_13">0</string>
    <string name="SectionFiveTheoryPropsAnswerTwo_13">1</string>
    <string name="SectionFiveTheoryPropsAnswerThree_13">2</string>
    <string name="SectionFiveTheoryPropsCorrectAnswer_13">1</string>

    <string name="SectionFiveTheoryWorkedExamples_13">• sin(30°) = ½, cos(30°) = √3/2: verify the identity — (½)² + (√3/2)² = ¼ + ¾ = 1 ✓.
\n • Since sine is odd: sin(−60°) = −sin(60°) = −√3/2. Since cosine is even: cos(−60°) = cos(60°) = ½.
\n • tan(45°) = sin(45°)/cos(45°) = (√2/2)/(√2/2) = 1; confirmed by the unit-circle point (√2/2, √2/2) at 45°.</string>

    <!-- Q: What is sin(30°)? Answer: 1/2 -->
    <string name="SectionFiveTheoryWorkedExQuestion_13">What is the value of sin(30°)?</string>
    <string name="SectionFiveTheoryWorkedExAnswerOne_13">√3/2</string>
    <string name="SectionFiveTheoryWorkedExAnswerTwo_13">√2/2</string>
    <string name="SectionFiveTheoryWorkedExAnswerThree_13">1/2</string>
    <string name="SectionFiveTheoryWorkedExCorrectAnswer_13">1/2</string>

