    <!--           SECTION SEVEN: LAW OF SINES & LAW OF COSINES          -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <!-- Fixed typos: 13R → 2R and 13bc → 2bc -->
    <string name="SectionSevenTheoryDef_13">• Theorem of Sines: a/sinα=b/sinβ=c/sinγ=2R.
\n • Theorem of Cosines: a²=b²+c²−2bc·cosα.
\n • Relates sides and angles of a triangle.</string>

    <!-- Q: In the Law of Sines, a/sinα equals 2R. What is R? Answer: circumscribed circle radius -->
    <string name="SectionSevenTheoryDefQuestion_13">In the Law of Sines, a/sinα = 2R. What does R represent?</string>
    <string name="SectionSevenTheoryDefAnswerOne_13">inscribed circle radius</string>
    <string name="SectionSevenTheoryDefAnswerTwo_13">circumscribed circle radius</string>
