    <!--              SECTION THREE: VECTOR COORDINATES                  -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <string name="SectionThreeTheoryDef_13">• A unit vector has length one.
\n • Any vector can be written as r⃗=xi⃗+yj⃗.
\n • Components show direction along axes.</string>

    <!-- Q: Does a unit vector have length equal to 1? Answer: True -->
    <string name="SectionThreeTheoryDefQuestion_13">Does a unit vector have length equal to 1?</string>
    <string name="SectionThreeTheoryDefAnswerOne_13">True</string>
    <string name="SectionThreeTheoryDefAnswerTwo_13">False</string>
    <!-- Only 2 answers for True/False — third answer intentionally removed -->
    <string name="SectionThreeTheoryDefAnswerThree_13"></string>
    <string name="SectionThreeTheoryDefCorrectAnswer_13">True</string>

    <string name="SectionThreeTheoryProperties_13">• Vector length: |r⃗|=√(x²+y²).
\n • Sums of vectors add by their coordinates.
\n • Coordinate form simplifies operations.</string>

    <!-- Q: Vector r⃗ = (3, 4). What is its length? Answer: 5 -->
    <string name="SectionThreeTheoryPropsQuestion_13">What is the length of vector r⃗ with coordinates (3, 4)?</string>
    <string name="SectionThreeTheoryPropsAnswerOne_13">7</string>
    <string name="SectionThreeTheoryPropsAnswerTwo_13">5</string>
    <string name="SectionThreeTheoryPropsAnswerThree_13">12</string>
    <string name="SectionThreeTheoryPropsCorrectAnswer_13">5</string>

    <string name="SectionThreeTheoryWorkedExamples_13">• For A(1, 2) and B(4, 6): AB⃗ = (4−1, 6−2) = (3, 4); length |AB⃗| = √(9+16) = √25 = 5.
\n • Sum of vectors (2, 3) and (−1, 5): (2+(−1), 3+5) = (1, 8); length = √(1+64) = √65.
\n • Scalar multiplication: 3×(2, −1) = (6, −3); length = √(36+9) = √45 = 3√5 — confirming the length scales by the same factor 3.</string>

    <!-- Q: For A(1,2) and B(4,6), what is the length of AB⃗? Answer: 5 -->
    <string name="SectionThreeTheoryWorkedExQuestion_13">For points A(1, 2) and B(4, 6), what is the length of vector AB⃗?</string>
    <string name="SectionThreeTheoryWorkedExAnswerOne_13">6</string>
    <string name="SectionThreeTheoryWorkedExAnswerTwo_13">7</string>
    <string name="SectionThreeTheoryWorkedExAnswerThree_13">5</string>
    <string name="SectionThreeTheoryWorkedExCorrectAnswer_13">5</string>

