    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!--                   SECTION TWO: MOTIONS (ISOMETRIES)             -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <string name="SectionTwoTheoryDef_12">• A motion keeps distances unchanged (isometry).
\n • Translation shifts points equally in one direction.
\n • Rotation turns a figure around a fixed point.</string>

    <!-- Q: Does a motion (isometry) preserve distances? Answer: True -->
    <string name="SectionTwoTheoryDefQuestion_12">Does a motion (isometry) preserve distances between points?</string>
    <string name="SectionTwoTheoryDefAnswerOne_12">True</string>
    <string name="SectionTwoTheoryDefAnswerTwo_12">False</string>
    <!-- Only 2 answers for True/False — third answer intentionally removed -->
    <string name="SectionTwoTheoryDefAnswerThree_12"></string>
    <string name="SectionTwoTheoryDefCorrectAnswer_12">True</string>

    <string name="SectionTwoTheoryProperties_12">• Motions preserve shapes, lengths, and angles.
\n • Combining motions yields another motion.
\n • Every figure is congruent to itself and others by motion.</string>

    <!-- Q: Does combining two motions always yield another motion? Answer: True -->
    <string name="SectionTwoTheoryPropsQuestion_12">Does combining two motions always result in another motion?</string>
    <string name="SectionTwoTheoryPropsAnswerOne_12">True</string>
    <string name="SectionTwoTheoryPropsAnswerTwo_12">False</string>
    <!-- Only 2 answers for True/False — third answer intentionally removed -->
    <string name="SectionTwoTheoryPropsAnswerThree_12"></string>
    <string name="SectionTwoTheoryPropsCorrectAnswer_12">True</string>

    <string name="SectionTwoTheoryWorkedExamples_12">• Proof that axial symmetry is a motion: for any two points P and Q and their reflections P′ and Q′ across line l, the reflecting triangles are congruent by SAS, so P′Q′ = PQ — distance is preserved.
\n • Uniqueness of translation: given points A and B, there is exactly one translation mapping A to B, defined by the vector AB⃗. Any other translation would send A to a different point.
\n • Combining a translation and a rotation produces a new isometry (a glide rotation), confirming that the set of all motions is closed under composition.</string>

    <!-- Q: Is axial symmetry a motion (isometry)? Answer: True -->
    <string name="SectionTwoTheoryWorkedExQuestion_12">Is axial symmetry (reflection across a line) classified as a motion (isometry)?</string>
    <string name="SectionTwoTheoryWorkedExAnswerOne_12">True</string>
    <string name="SectionTwoTheoryWorkedExAnswerTwo_12">False</string>
    <!-- Only 2 answers for True/False — third answer intentionally removed -->
    <string name="SectionTwoTheoryWorkedExAnswerThree_12"></string>
    <string name="SectionTwoTheoryWorkedExCorrectAnswer_12">True</string>

