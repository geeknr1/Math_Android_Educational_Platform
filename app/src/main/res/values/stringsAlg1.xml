    <string name="SectionSixTheoryDef">Numbers are shown on a line: positives right, negatives left.\n
|a| (modulus) means distance from zero:\n
◦ |a| = a if a ≥ 0.\n
◦ |a| = -a if a &lt; 0.</string>
    <string name="SectionSixTheoryDefQuestion">What is |-7|?</string>
    <string name="SectionSixTheoryDefAnswerOne">-7</string>
    <string name="SectionSixTheoryDefAnswerTwo">0</string>
    <string name="SectionSixTheoryDefAnswerThree">7</string>
    <string name="SectionSixTheoryDefCorrectAnswer">7</string>

    <string name="SectionSixTheoryProperties">Modulus properties:\n
◦ |a| ≥ 0 and |a| = 0 only for a=0.\n
◦ |a| = |-a|.\n
◦ |ab| = |a||b|, |a/b| = |a|/|b| (b ≠ 0).</string>
    <string name="SectionSixTheoryPropsQuestion">Is |-5| = |5|? (True / False)</string>
    <string name="SectionSixTheoryPropsAnswerOne">True</string>
    <string name="SectionSixTheoryPropsAnswerTwo">False</string>
    <string name="SectionSixTheoryPropsAnswerThree">Neither</string>
    <string name="SectionSixTheoryPropsCorrectAnswer">True</string>

