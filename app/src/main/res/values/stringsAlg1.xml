    <string name="SectionFourTheoryDef">A fraction is the result of dividing two whole numbers a and b (b ≠ 0), written as a/b.</string>
    <string name="SectionFourTheoryDefQuestion">What is the result of 3/4 + 1/4?</string>
    <string name="SectionFourTheoryDefAnswerOne">1/2</string>
    <string name="SectionFourTheoryDefAnswerTwo">1</string>
    <string name="SectionFourTheoryDefAnswerThree">4/4</string>
    <string name="SectionFourTheoryDefCorrectAnswer">1</string>


    <string name="SectionFourTheoryProperties">Properties:\n
◦ a/b = c/d if ad = bc.\n
◦ Multiplying or dividing numerator and denominator by the same number doesn\'t change its value.\n
◦ Addition: a/b + c/d = (ad + bc)/bd.\n
◦ Division: (a/b) ÷ (c/d) = ad/bc.</string>
    <string name="SectionFourTheoryPropsQuestion">What is (2/3) ÷ (4/9)?</string>
    <string name="SectionFourTheoryPropsAnswerOne">8/27</string>
    <string name="SectionFourTheoryPropsAnswerTwo">3/2</string>
    <string name="SectionFourTheoryPropsAnswerThree">2/3</string>
    <string name="SectionFourTheoryPropsCorrectAnswer">3/2</string>

    <string name="SectionFourTheoryWorkedExamples">Simplify the fraction 18/24.\n
Step 1: Find the G.C.D. of 18 and 24: G.C.D. = 6.\n
Step 2: Divide both numerator and denominator by 6.\n
Step 3: 18/24 = 3/4.</string>
    <string name="SectionFourTheoryWorkedExQuestion">What is 18/24 simplified to its lowest terms?</string>
    <string name="SectionFourTheoryWorkedExAnswerOne">2/3</string>
    <string name="SectionFourTheoryWorkedExAnswerTwo">9/12</string>
    <string name="SectionFourTheoryWorkedExAnswerThree">3/4</string>
    <string name="SectionFourTheoryWorkedExCorrectAnswer">3/4</string>

