    <string name="SectionThreeTheoryDef">Definitions:\n
• Common Divisor: divides all given numbers.\n
• G.C.D.: largest common divisor.\n
• Relatively Prime: G.C.D. = 1.\n
• L.C.M.: smallest common multiple.</string>
    <string name="SectionThreeTheoryDefQuestion">What is the G.C.D. of 12 and 18?</string>
    <string name="SectionThreeTheoryDefAnswerOne">3</string>
    <string name="SectionThreeTheoryDefAnswerTwo">6</string>
    <string name="SectionThreeTheoryDefAnswerThree">9</string>
    <string name="SectionThreeTheoryDefCorrectAnswer">6</string>


    <string name="SectionThreeTheoryProperties">Relatively prime numbers have these properties:\n
1. If a number is divisible by two relatively prime numbers, it is divisible by their product.\n
2. If ab is divisible by c and b, c are relatively prime, then a is divisible by c.</string>
    <string name="SectionThreeTheoryPropsQuestion">Are 8 and 15 relatively prime? (True / False)</string>
    <string name="SectionThreeTheoryPropsAnswerOne">True</string>
    <string name="SectionThreeTheoryPropsAnswerTwo">False</string>
    <string name="SectionThreeTheoryPropsAnswerThree">Neither</string>
    <string name="SectionThreeTheoryPropsCorrectAnswer">True</string>


    <string name="SectionThreeTheoryWorkedExamples">Find the L.C.M. of 4 and 6.\n
Step 1: 4 = 2², 6 = 2 · 3.\n
Step 2: Take the highest power of each prime: 2² and 3.\n
Step 3: L.C.M. = 2² · 3 = 12.</string>
    <string name="SectionThreeTheoryWorkedExQuestion">What is the L.C.M. of 4 and 6?</string>
    <string name="SectionThreeTheoryWorkedExAnswerOne">8</string>
    <string name="SectionThreeTheoryWorkedExAnswerTwo">12</string>
    <string name="SectionThreeTheoryWorkedExAnswerThree">24</string>
    <string name="SectionThreeTheoryWorkedExCorrectAnswer">12</string>

