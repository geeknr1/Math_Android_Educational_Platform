    <string name="SectionTwoTheoryDef">Definitions:\n
◦ Divisor: divides another number with no remainder.\n
◦ Prime: has only two divisors (1 and itself).\n
◦ Composite: has more than two divisors.\n
◦ Unity (1): neither prime nor composite.</string>
    <string name="SectionTwoTheoryDefQuestion">What divisors does the prime number have?</string>
    <string name="SectionTwoTheoryDefAnswerOne">one</string>
    <string name="SectionTwoTheoryDefAnswerTwo">two</string>
    <string name="SectionTwoTheoryDefAnswerThree">three</string>
    <string name="SectionTwoTheoryDefCorrectAnswer">one</string>

    <string name="SectionTwoTheoryProperties">Any number >1 can be written uniquely as a product of primes.\n
Divisibility rules:\n
◦ By 2 or 5: check whether the last digit is even (divisibility by 2) ; whether the last digit is 5 or 0.\n
◦ By 3 or 9: sum of digits divisible by 3 or 9.\n
◦ By 6: divisible by both 2 and 3.</string>
    <string name="SectionTwoTheoryPropsQuestion">Is 126 divisible by 6? (True / False)</string>
    <string name="SectionTwoTheoryPropsAnswerOne">True</string>
    <string name="SectionTwoTheoryPropsAnswerTwo">False</string>
    <string name="SectionTwoTheoryPropsAnswerThree">Neither</string>
    <string name="SectionTwoTheoryPropsCorrectAnswer">True</string>

    <string name="SectionTwoTheoryWorkedExamples">Write 60 as a product of prime numbers.</string>
    <string name="SectionTwoTheoryWorkedExQuestion">What is the prime factorization of 60?</string>
    <string name="SectionTwoTheoryWorkedExAnswerOne">2² · 3 · 5</string>
    <string name="SectionTwoTheoryWorkedExAnswerTwo">2 · 5 · 6</string>
    <string name="SectionTwoTheoryWorkedExAnswerThree">4 · 3 · 5</string>
    <string name="SectionTwoTheoryWorkedExCorrectAnswer">2² · 3 · 5</string>

