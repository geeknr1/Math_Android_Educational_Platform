    <string name="SectionOneTheoryDef">Natural numbers are used for counting objects (1, 2, 3, ...). They have a smallest number (1) but no largest. Whole numbers extend them by including zero and negatives (..., -2, -1, 0, 1, 2, ...).</string>
    <string name="SectionOneTheoryDefQuestion">What is the main difference between natural numbers and whole numbers?</string>
    <string name="SectionOneTheoryDefAnswerOne">one</string>
    <string name="SectionOneTheoryDefAnswerTwo">two</string>
    <string name="SectionOneTheoryDefAnswerThree">three</string>
    <string name="SectionOneTheoryDefCorrectAnswer">one</string>

    <string name="SectionOneTheoryProperties">For any whole numbers a, b, and c:\n
◦ Commutative: a + b = b + a, a·b = b·a.\n
◦ Associative: (a + b) + c = a + (b + c).\n
◦ Distributive: (a + b)·c = a·c + b·c.\n
◦ Zero and Unity: a + 0 = a, a·0 = 0, a·1 = a.</string>
    <string name="SectionOneTheoryPropsQuestion">Which property is shown in the equation:\n 2 + 5 = 5 + 2 ?</string>
    <string name="SectionOneTheoryPropsAnswerOne">one</string>
    <string name="SectionOneTheoryPropsAnswerTwo">two</string>
    <string name="SectionOneTheoryPropsAnswerThree">three</string>
    <string name="SectionOneTheoryPropsCorrectAnswer">two</string>

    <string name="SectionOneTheoryWorkedExamples">!!! Worked Examples !!!</string>
