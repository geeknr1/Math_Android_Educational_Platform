    <string name="SectionFiveTheoryDef">A rational number can be written as a/b, where a and b are integers and b ≠ 0. All whole numbers and fractions are rational.</string>
    <string name="SectionFiveTheoryDefQuestion">Is every fraction a rational number? (True / False)</string>
    <string name="SectionFiveTheoryDefAnswerOne">True</string>
    <string name="SectionFiveTheoryDefAnswerTwo">False</string>
    <string name="SectionFiveTheoryDefAnswerThree">Neither</string>
    <string name="SectionFiveTheoryDefCorrectAnswer">True</string>


    <string name="SectionFiveTheoryProperties">Decimal forms:\n
◦ Terminating: denominator has only 2s or 5s.\n
◦ Nonterminating: denominator has other primes.\n
◦ Periodic: digits or blocks repeat infinitely.</string>
    <string name="SectionFiveTheoryPropsQuestion">Which decimal form does 1/8 have?</string>
    <string name="SectionFiveTheoryPropsAnswerOne">Periodic</string>
    <string name="SectionFiveTheoryPropsAnswerTwo">Terminating</string>
    <string name="SectionFiveTheoryPropsAnswerThree">Nonterminating non-periodic</string>
    <string name="SectionFiveTheoryPropsCorrectAnswer">Terminating</string>


    <string name="SectionFiveTheoryWorkedExamples">Convert 0.333... to a fraction.\n
Step 1: Let x = 0.333...\n
Step 2: Then 10x = 3.333...\n
Step 3: Subtract: 10x − x = 3, so 9x = 3.\n
Step 4: x = 3/9 = 1/3.</string>
