    <!-- ===================== SECTION TWELVE: Linear and Quadratic Inequalities ===================== -->
    <string name="SectionTwelveTheoryDef_5">Linear: ax+b&gt;0 → ray. Quadratic: ax²+bx+c&gt;0 → depends on D and sign of a.</string>
    <string name="SectionTwelveTheoryDefQuestion_5">For ax²+bx+c &gt; 0 with a &gt; 0 and D &lt; 0, is the solution all real numbers?</string>
    <string name="SectionTwelveTheoryDefAnswerOne_5">True</string>
    <string name="SectionTwelveTheoryDefAnswerTwo_5">False</string>
    <string name="SectionTwelveTheoryDefAnswerThree_5">Neither</string>
    <string name="SectionTwelveTheoryDefCorrectAnswer_5">True</string>

    <string name="SectionTwelveTheoryProperties_5">For ax²+bx+c &gt; 0 with a &gt; 0: if D &gt; 0 the solution is (−∞, x₁) ∪ (x₂, +∞); if D = 0 it is all x ≠ x₁; if D &lt; 0 it is all real numbers. For a &lt; 0 the cases reverse.</string>
    <string name="SectionTwelveTheoryPropsQuestion_5">For x² − 4 &gt; 0, is x = 3 a solution?</string>
    <string name="SectionTwelveTheoryPropsAnswerOne_5">True</string>
    <string name="SectionTwelveTheoryPropsAnswerTwo_5">False</string>
    <string name="SectionTwelveTheoryPropsAnswerThree_5">Neither</string>
    <string name="SectionTwelveTheoryPropsCorrectAnswer_5">True</string>

    <string name="SectionTwelveTheoryWorkedExamples_5">Example 1: Solve 2x − 4 &gt; 0. Divide by 2: x &gt; 2. Solution: (2, +∞). \n
Example 2: Solve x² − 5x + 6 &gt; 0. Roots: x=2, x=3 (D=1&gt;0, a&gt;0). Solution: (−∞,2) ∪ (3,+∞). \n
Example 3: Solve x² + 2x + 1 &gt; 0. One root x=−1 (D=0, a&gt;0). Solution: all x ≠ −1. </string>
    <string name="SectionTwelveTheoryWorkedExQuestion_5">What is the boundary value in the solution of 2x − 8 &gt; 0 (what is x greater than)?</string>
    <string name="SectionTwelveTheoryWorkedExAnswerOne_5">2</string>
    <string name="SectionTwelveTheoryWorkedExAnswerTwo_5">4</string>
    <string name="SectionTwelveTheoryWorkedExAnswerThree_5">8</string>
    <string name="SectionTwelveTheoryWorkedExCorrectAnswer_5">4</string>

