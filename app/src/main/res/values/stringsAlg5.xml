    <!-- ===================== SECTION TEN: Inequalities – Definition ===================== -->
    <string name="SectionTenTheoryDef_5">Inequalities: &gt;, &lt;, ≥, ≤. Domain = valid variable values. Solution makes statement true.</string>
    <string name="SectionTenTheoryDefQuestion_5">Is x = 4 a solution of the inequality 2x − 5 &gt; 0?</string>
    <string name="SectionTenTheoryDefAnswerOne_5">True</string>
    <string name="SectionTenTheoryDefAnswerTwo_5">False</string>
    <string name="SectionTenTheoryDefAnswerThree_5">Neither</string>
    <string name="SectionTenTheoryDefCorrectAnswer_5">True</string>

    <string name="SectionTenTheoryProperties_5">Use transitivity, addition, multiplication rules. Equivalent inequalities share solutions.</string>
    <string name="SectionTenTheoryPropsQuestion_5">When multiplying both sides of an inequality by a negative number, does the inequality sign reverse?</string>
    <string name="SectionTenTheoryPropsAnswerOne_5">True</string>
    <string name="SectionTenTheoryPropsAnswerTwo_5">False</string>
    <string name="SectionTenTheoryPropsAnswerThree_5">Neither</string>
    <string name="SectionTenTheoryPropsCorrectAnswer_5">True</string>

    <string name="SectionTenTheoryWorkedExamples_5">Example 1: Solve 2x − 4 &gt; 0. Add 4: 2x &gt; 4. Divide by 2: x &gt; 2. Solution: (2, +∞). \n
Example 2: Solve −3x ≤ 9. Divide by −3 (flip sign): x ≥ −3. Solution: [−3, +∞). \n
Example 3: Solve x + 1 &lt; 5. Subtract 1: x &lt; 4. Solution: (−∞, 4). </string>
    <string name="SectionTenTheoryWorkedExQuestion_5">What is the solution boundary of 3x &gt; 12 (i.e., what value does x exceed)?</string>
    <string name="SectionTenTheoryWorkedExAnswerOne_5">3</string>
    <string name="SectionTenTheoryWorkedExAnswerTwo_5">4</string>
    <string name="SectionTenTheoryWorkedExAnswerThree_5">5</string>
    <string name="SectionTenTheoryWorkedExCorrectAnswer_5">4</string>

