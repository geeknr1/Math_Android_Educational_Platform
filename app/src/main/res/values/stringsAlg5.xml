    <!-- ===================== SECTION SIX: Equations with Several Unknowns ===================== -->
    <string name="SectionSixTheoryDef_5">Equations with several unknowns (e.g., x+2y=3). Solutions are ordered pairs/triples.</string>
    <string name="SectionSixTheoryDefQuestion_5">Is (1, 1) a solution of x + 2y = 3?</string>
    <string name="SectionSixTheoryDefAnswerOne_5">True</string>
    <string name="SectionSixTheoryDefAnswerTwo_5">False</string>
    <string name="SectionSixTheoryDefAnswerThree_5">Neither</string>
    <string name="SectionSixTheoryDefCorrectAnswer_5">True</string>

    <string name="SectionSixTheoryProperties_5">Systems solved simultaneously; may have one, none, or ∞ solutions.</string>
    <string name="SectionSixTheoryPropsQuestion_5">How many solutions can a system of two equations in two unknowns have at most if the lines are parallel?</string>
    <string name="SectionSixTheoryPropsAnswerOne_5">0</string>
    <string name="SectionSixTheoryPropsAnswerTwo_5">1</string>
    <string name="SectionSixTheoryPropsAnswerThree_5">∞</string>
    <string name="SectionSixTheoryPropsCorrectAnswer_5">0</string>

    <string name="SectionSixTheoryWorkedExamples_5">Example 1: Is (2, 1) a solution of x + 2y = 4? Check: 2 + 2·1 = 4. \n.
Example 2: Is (0, 3) a solution of x + 2y = 3? Check: 0 + 6 = 6 ≠ 3. \n.
Example 3: How many solutions does x + y = 5 have? Infinitely many ordered pairs (e.g. (1,4), (2,3), …). \n</string>
