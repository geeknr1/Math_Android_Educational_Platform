    <!-- ===================== SECTION SEVEN: Systems of Linear Equations ===================== -->
    <string name="SectionSevenTheoryDef_5">System: a₁x+b₁y=c₁; a₂x+b₂y=c₂. Solve by substitution or addition.</string>
    <string name="SectionSevenTheoryDefQuestion_5">What is the x-value in the solution of the system: x+y=5 and x−y=1?</string>
    <string name="SectionSevenTheoryDefAnswerOne_5">2</string>
    <string name="SectionSevenTheoryDefAnswerTwo_5">3</string>
    <string name="SectionSevenTheoryDefAnswerThree_5">4</string>
    <string name="SectionSevenTheoryDefCorrectAnswer_5">3</string>

    <string name="SectionSevenTheoryProperties_5">Cases: unique, none, or ∞. Lines intersect, parallel, or coincide.</string>
    <string name="SectionSevenTheoryPropsQuestion_5">Do two parallel lines correspond to a system with no solution?</string>
    <string name="SectionSevenTheoryPropsAnswerOne_5">True</string>
    <string name="SectionSevenTheoryPropsAnswerTwo_5">False</string>
    <string name="SectionSevenTheoryPropsAnswerThree_5">Neither</string>
    <string name="SectionSevenTheoryPropsCorrectAnswer_5">True</string>

    <string name="SectionSevenTheoryWorkedExamples_5">Example 1: Solve x+y=5 and x−y=1. Add: 2x=6, x=3. Then y=2. Solution: (3,2). \n
Example 2: Solve 2x+y=7 and x−y=2. Add: 3x=9, x=3. Then y=1. Solution: (3,1). \n
Example 3: Solve x+y=3 and x+y=5. No solution — parallel lines. \n</string>
    <string name="SectionSevenTheoryWorkedExQuestion_5">What is the y-value in the solution of x+y=5 and x−y=1?</string>
    <string name="SectionSevenTheoryWorkedExAnswerOne_5">1</string>
