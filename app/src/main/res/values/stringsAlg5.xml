    <!-- ===================== SECTION TWO: Linear Equations ===================== -->
    <string name="SectionTwoTheoryDef_5">Linear eq: ax=b (a≠0). First-degree equation in one unknown.</string>
    <string name="SectionTwoTheoryDefQuestion_5">Is ax = b a linear equation when a = 0?</string>
    <string name="SectionTwoTheoryDefAnswerOne_5">True</string>
    <string name="SectionTwoTheoryDefAnswerTwo_5">False</string>
    <string name="SectionTwoTheoryDefAnswerThree_5">Neither</string>
    <string name="SectionTwoTheoryDefCorrectAnswer_5">False</string>

    <string name="SectionTwoTheoryProperties_5">If a≠0 → x=b/a. If a=0 → none or ∞ roots. ax=x+1 → one root if a≠1.</string>
    <string name="SectionTwoTheoryPropsQuestion_5">What is the solution of 4x = 20?</string>
    <string name="SectionTwoTheoryPropsAnswerOne_5">4</string>
    <string name="SectionTwoTheoryPropsAnswerTwo_5">5</string>
    <string name="SectionTwoTheoryPropsAnswerThree_5">6</string>
    <string name="SectionTwoTheoryPropsCorrectAnswer_5">5</string>

    <string name="SectionTwoTheoryWorkedExamples_5">Example 1: Solve 3x = 12. Divide by 3: x = 4. \n
Example 2: Solve 5x − 10 = 0. Add 10: 5x = 10, divide by 5: x = 2. \n
Example 3: Solve 0·x = 5. No solution exists (a = 0, b ≠ 0). </string>
