    <!-- ===================== SECTION ELEVEN: Proving Inequalities ===================== -->
    <string name="SectionElevenTheoryDef_5">Prove inequalities via direct/equivalent transformations. Use AM-GM, triangle, modulus properties.</string>
    <string name="SectionElevenTheoryDefQuestion_5">Is (a − b)² ≥ 0 always true for any real a, b?</string>
    <string name="SectionElevenTheoryDefAnswerOne_5">True</string>
    <string name="SectionElevenTheoryDefAnswerTwo_5">False</string>
    <string name="SectionElevenTheoryDefAnswerThree_5">Neither</string>
    <string name="SectionElevenTheoryDefCorrectAnswer_5">True</string>

    <string name="SectionElevenTheoryProperties_5">Reduce to known forms like (a−b)²≥0. Apply mean and modulus inequalities.</string>
    <string name="SectionElevenTheoryPropsQuestion_5">By the AM-GM inequality, is (a + b)/2 ≥ √(ab) true for non-negative a and b?</string>
    <string name="SectionElevenTheoryPropsAnswerOne_5">True</string>
    <string name="SectionElevenTheoryPropsAnswerTwo_5">False</string>
    <string name="SectionElevenTheoryPropsAnswerThree_5">Neither</string>
    <string name="SectionElevenTheoryPropsCorrectAnswer_5">True</string>

    <string name="SectionElevenTheoryWorkedExamples_5">Example 1: Prove a² + b² ≥ 2ab. Rearrange: a² − 2ab + b² ≥ 0 → (a−b)² ≥ 0. Always true. \n
Example 2: Prove |a + b| ≤ |a| + |b| (triangle inequality). Follows from properties of absolute value. \n
Example 3: For a,b &gt; 0, prove (a+b)/2 ≥ √(ab). Equivalent to (√a − √b)² ≥ 0. Always true. </string>
    <string name="SectionElevenTheoryWorkedExQuestion_5">What is the minimum value of (a − b)² for any real a, b?</string>
    <string name="SectionElevenTheoryWorkedExAnswerOne_5">-1</string>
    <string name="SectionElevenTheoryWorkedExAnswerTwo_5">0</string>
    <string name="SectionElevenTheoryWorkedExAnswerThree_5">1</string>
    <string name="SectionElevenTheoryWorkedExCorrectAnswer_5">0</string>

