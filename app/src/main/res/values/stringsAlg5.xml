    <!-- ===================== SECTION THREE: Quadratic Equations ===================== -->
    <string name="SectionThreeTheoryDef_5">Quadratic: ax²+bx+c=0, a≠0. D=b²−4ac decides roots. Formula: x=(-b±√D)/2a. Viète: x₁+x₂=-b/a, x₁x₂=c/a.</string>
    <string name="SectionThreeTheoryDefQuestion_5">How many roots does ax²+bx+c=0 have when D = 0?</string>
    <string name="SectionThreeTheoryDefAnswerOne_5">0</string>
    <string name="SectionThreeTheoryDefAnswerTwo_5">1</string>
    <string name="SectionThreeTheoryDefAnswerThree_5">2</string>
    <string name="SectionThreeTheoryDefCorrectAnswer_5">1</string>

    <string name="SectionThreeTheoryProperties_5">Viète links roots and coefficients. D>0→2 roots, D=0→1, D&lt;0→none.</string>
    <string name="SectionThreeTheoryPropsQuestion_5">For x²− 5x + 6 = 0, what is the product of the roots (x₁·x₂)?</string>
    <string name="SectionThreeTheoryPropsAnswerOne_5">5</string>
    <string name="SectionThreeTheoryPropsAnswerTwo_5">6</string>
    <string name="SectionThreeTheoryPropsAnswerThree_5">-6</string>
    <string name="SectionThreeTheoryPropsCorrectAnswer_5">6</string>

    <string name="SectionThreeTheoryWorkedExamples_5">Example 1: Solve x² − 5x + 6 = 0. D = 25 − 24 = 1. x = (5 ± 1)/2 → x₁ = 3, x₂ = 2. \n
Example 2: Solve x² − 4x + 4 = 0. D = 16 − 16 = 0. x = 4/2 = 2 (one root). \n
Example 3: Solve x² + x + 1 = 0. D = 1 − 4 = −3 &lt; 0. No real roots. </string>
    <string name="SectionThreeTheoryWorkedExQuestion_5">What is the discriminant D of x² − 4x + 3 = 0?</string>
    <string name="SectionThreeTheoryWorkedExAnswerOne_5">4</string>
    <string name="SectionThreeTheoryWorkedExAnswerTwo_5">8</string>
    <string name="SectionThreeTheoryWorkedExAnswerThree_5">12</string>
    <string name="SectionThreeTheoryWorkedExCorrectAnswer_5">4</string>

