    <!-- ===================== SECTION EIGHT: Equations with Parameters ===================== -->
    <string name="SectionEightTheoryDef_5">Maintain equivalence. Analyze parameter effects and domains. Substitution helps simplify.</string>
    <string name="SectionEightTheoryDefQuestion_5">In ax = b, if a = 0 and b ≠ 0, how many solutions does the equation have?</string>
    <string name="SectionEightTheoryDefAnswerOne_5">0</string>
    <string name="SectionEightTheoryDefAnswerTwo_5">1</string>
    <string name="SectionEightTheoryDefAnswerThree_5">∞</string>
    <string name="SectionEightTheoryDefCorrectAnswer_5">0</string>

    <string name="SectionEightTheoryProperties_5">Handle linear, quadratic, irrational, and system equations with parameters carefully.</string>
    <string name="SectionEightTheoryPropsQuestion_5">For the equation ax² + bx + c = 0 to have two distinct real roots, must D be greater than 0?</string>
    <string name="SectionEightTheoryPropsAnswerOne_5">True</string>
    <string name="SectionEightTheoryPropsAnswerTwo_5">False</string>
    <string name="SectionEightTheoryPropsAnswerThree_5">Neither</string>
    <string name="SectionEightTheoryPropsCorrectAnswer_5">True</string>

    <string name="SectionEightTheoryWorkedExamples_5">Example 1: Solve ax = 3. If a≠0: x = 3/a. If a=0: no solution. \n
Example 2: Solve (a−1)x = 2. If a≠1: x = 2/(a−1). If a=1: no solution. \n
Example 3: Solve ax² = 4. If a&gt;0: x = ±2/√a. If a=0: no solution. If a&lt;0: no real solution. \n</string>
    <string name="SectionEightTheoryWorkedExQuestion_5">For (a−2)x = 0, how many solutions exist when a = 2?</string>
    <string name="SectionEightTheoryWorkedExAnswerOne_5">0</string>
    <string name="SectionEightTheoryWorkedExAnswerTwo_5">1</string>
    <string name="SectionEightTheoryWorkedExAnswerThree_5">∞</string>
    <string name="SectionEightTheoryWorkedExCorrectAnswer_5">∞</string>

