    <!-- ===================== SECTION ONE: Equations – Definition ===================== -->
    <string name="SectionOneTheoryDef_5">Equation: A=B for some variable values. Unknowns x,y,z; parameters a,b,c.</string>
    <string name="SectionOneTheoryDefQuestion_5">Is x=3 a root of the equation 2x − 6 = 0?</string>
    <string name="SectionOneTheoryDefAnswerOne_5">True</string>
    <string name="SectionOneTheoryDefAnswerTwo_5">False</string>
    <string name="SectionOneTheoryDefAnswerThree_5">Neither</string>
    <string name="SectionOneTheoryDefCorrectAnswer_5">True</string>

    <string name="SectionOneTheoryProperties_5">Root makes equality true. Equivalent equations share roots. Transform carefully to avoid false roots.</string>
    <string name="SectionOneTheoryPropsQuestion_5">Which value of x satisfies 3x − 9 = 0?</string>
    <string name="SectionOneTheoryPropsAnswerOne_5">2</string>
    <string name="SectionOneTheoryPropsAnswerTwo_5">3</string>
    <string name="SectionOneTheoryPropsAnswerThree_5">4</string>
    <string name="SectionOneTheoryPropsCorrectAnswer_5">3</string>

    <string name="SectionOneTheoryWorkedExamples_5">Example 1: Solve x + 5 = 12. Subtract 5 from both sides: x = 7. ✓ Check: 7 + 5 = 12.
Example 2: Solve 2x = 10. Divide both sides by 2: x = 5. ✓ Check: 2·5 = 10.
Example 3: Solve x/3 = 4. Multiply both sides by 3: x = 12. ✓ Check: 12/3 = 4.</string>
    <string name="SectionOneTheoryWorkedExQuestion_5">What is the root of the equation x + 7 = 15?</string>
    <string name="SectionOneTheoryWorkedExAnswerOne_5">6</string>
    <string name="SectionOneTheoryWorkedExAnswerTwo_5">7</string>
    <string name="SectionOneTheoryWorkedExAnswerThree_5">8</string>
    <string name="SectionOneTheoryWorkedExCorrectAnswer_5">8</string>

