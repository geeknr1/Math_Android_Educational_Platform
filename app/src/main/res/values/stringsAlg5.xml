    <!-- ===================== SECTION FOUR: Factoring a Quadratic Trinomial ===================== -->
    <string name="SectionFourTheoryDef_5">Quadratic trinomial ax²+bx+c=0 → roots x₁,x₂.</string>
    <string name="SectionFourTheoryDefQuestion_5">Is it true that ax²+bx+c = a(x−x₁)(x−x₂) when x₁ and x₂ are the roots?</string>
    <string name="SectionFourTheoryDefAnswerOne_5">True</string>
    <string name="SectionFourTheoryDefAnswerTwo_5">False</string>
    <string name="SectionFourTheoryDefAnswerThree_5">Neither</string>
    <string name="SectionFourTheoryDefCorrectAnswer_5">True</string>

    <string name="SectionFourTheoryProperties_5">Factor form: a(x−x₁)(x−x₂), from Viète\'s theorem.</string>
    <string name="SectionFourTheoryPropsQuestion_5">Factor x² − 7x + 12. What are the roots x₁ and x₂ (enter the larger root)?</string>
    <string name="SectionFourTheoryPropsAnswerOne_5">3</string>
    <string name="SectionFourTheoryPropsAnswerTwo_5">4</string>
    <string name="SectionFourTheoryPropsAnswerThree_5">5</string>
    <string name="SectionFourTheoryPropsCorrectAnswer_5">4</string>

    <string name="SectionFourTheoryWorkedExamples_5">Example 1: Factor x² − 5x + 6. Roots: x₁=2, x₂=3 → (x−2)(x−3). \n
Example 2: Factor 2x² − 8x + 6. Roots: x₁=1, x₂=3 → 2(x−1)(x−3). \n
Example 3: Factor x² − 4. Roots: x₁=2, x₂=−2 → (x−2)(x+2).</string>
    <string name="SectionFourTheoryWorkedExQuestion_5">What is the factored form of x² − 9? Enter the positive root.</string>
