    <!-- ===================== SECTION THIRTEEN: Systems of Inequalities and Modulus ===================== -->
    <string name="SectionThirteenTheoryDef_5">Systems of inequalities → intersection of solution sets. |x|≤a ⇔ -a≤x≤a; |x|≥a ⇔ x≥a or x≤-a.</string>
    <string name="SectionThirteenTheoryDefQuestion_5">How many integer solutions does |x| ≤ 2 have?</string>
    <string name="SectionThirteenTheoryDefAnswerOne_5">3</string>
    <string name="SectionThirteenTheoryDefAnswerTwo_5">4</string>
    <string name="SectionThirteenTheoryDefAnswerThree_5">5</string>
    <string name="SectionThirteenTheoryDefCorrectAnswer_5">5</string>

    <string name="SectionThirteenTheoryProperties_5">The solution of a system of inequalities is the intersection of all individual solution sets. If this intersection is empty, the system has no solution.</string>
    <string name="SectionThirteenTheoryPropsQuestion_5">Does |x| ≥ 3 have a solution for x = −4?</string>
    <string name="SectionThirteenTheoryPropsAnswerOne_5">True</string>
    <string name="SectionThirteenTheoryPropsAnswerTwo_5">False</string>
    <string name="SectionThirteenTheoryPropsAnswerThree_5">Neither</string>
    <string name="SectionThirteenTheoryPropsCorrectAnswer_5">True</string>

    <string name="SectionThirteenTheoryWorkedExamples_5">Example 1: Solve |x| ≤ 3. Equivalent: −3 ≤ x ≤ 3. Solution: [−3, 3]. \n
Example 2: Solve |x − 1| &lt; 2. Equivalent: −2 &lt; x−1 &lt; 2 → −1 &lt; x &lt; 3. Solution: (−1, 3). \n
Example 3: Solve the system x &gt; 1 and x &lt; 4. Intersection: 1 &lt; x &lt; 4. Solution: (1, 4). </string>
    <string name="SectionThirteenTheoryWorkedExQuestion_5">What is the largest integer solution of |x| ≤ 3?</string>
    <string name="SectionThirteenTheoryWorkedExAnswerOne_5">2</string>
    <string name="SectionThirteenTheoryWorkedExAnswerTwo_5">3</string>
    <string name="SectionThirteenTheoryWorkedExAnswerThree_5">4</string>
    <string name="SectionThirteenTheoryWorkedExCorrectAnswer_5">3</string>

