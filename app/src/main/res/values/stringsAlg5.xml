    <!-- ===================== SECTION FIVE: Higher-Degree Equations ===================== -->
    <string name="SectionFiveTheoryDef_5">Higher-degree eq: a₀xⁿ+...+aₙ=0. Use factoring or substitution. Biquadratic: ax⁴+bx²+c=0 → y=x².</string>
    <string name="SectionFiveTheoryDefQuestion_5">In the biquadratic equation ax⁴+bx²+c=0, what substitution is used?</string>
    <string name="SectionFiveTheoryDefAnswerOne_5">y = x</string>
    <string name="SectionFiveTheoryDefAnswerTwo_5">y = x²</string>
    <string name="SectionFiveTheoryDefAnswerThree_5">y = x³</string>
    <string name="SectionFiveTheoryDefCorrectAnswer_5">y = x²</string>

    <string name="SectionFiveTheoryProperties_5">Factoring lowers degree. Substitution simplifies radicals. Check for extraneous roots.</string>
    <string name="SectionFiveTheoryPropsQuestion_5">Is it necessary to check for extraneous roots after using substitution?</string>
    <string name="SectionFiveTheoryPropsAnswerOne_5">True</string>
    <string name="SectionFiveTheoryPropsAnswerTwo_5">False</string>
    <string name="SectionFiveTheoryPropsAnswerThree_5">Neither</string>
    <string name="SectionFiveTheoryPropsCorrectAnswer_5">True</string>

    <string name="SectionFiveTheoryWorkedExamples_5">Example 1: Solve x⁴ − 5x² + 4 = 0. Let y = x². Then y² − 5y + 4 = 0 → y₁=1, y₂=4. So x² = 1 → x = ±1; x² = 4 → x = ±2. Four roots total. \n
Example 2: Solve x³ − 8 = 0. Factor: (x−2)(x²+2x+4) = 0. Real root: x = 2. \n
Example 3: Solve x⁴ − 16 = 0. Factor: (x²−4)(x²+4) = 0 → x = ±2. </string>
    <string name="SectionFiveTheoryWorkedExQuestion_5">How many real roots does x⁴ − 5x² + 4 = 0 have?</string>
    <string name="SectionFiveTheoryWorkedExAnswerOne_5">2</string>
    <string name="SectionFiveTheoryWorkedExAnswerTwo_5">3</string>
    <string name="SectionFiveTheoryWorkedExAnswerThree_5">4</string>
    <string name="SectionFiveTheoryWorkedExCorrectAnswer_5">4</string>

