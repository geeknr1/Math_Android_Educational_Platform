    <!-- ===================== SECTION NINE: Word Problems ===================== -->
    <string name="SectionNineTheoryDef_5">Word Problems: define unknowns, express conditions, form equations, choose solving method.</string>
    <string name="SectionNineTheoryDefQuestion_5">A number increased by 8 equals 20. What is the number?</string>
    <string name="SectionNineTheoryDefAnswerOne_5">10</string>
    <string name="SectionNineTheoryDefAnswerTwo_5">12</string>
    <string name="SectionNineTheoryDefAnswerThree_5">14</string>
    <string name="SectionNineTheoryDefCorrectAnswer_5">12</string>

    <string name="SectionNineTheoryProperties_5">To solve a word problem: (1) define the unknown, (2) write an equation from the conditions, (3) solve, (4) verify the answer in the original context.</string>
    <string name="SectionNineTheoryPropsQuestion_5">The sum of two consecutive integers is 31. What is the smaller integer?</string>
    <string name="SectionNineTheoryPropsAnswerOne_5">14</string>
    <string name="SectionNineTheoryPropsAnswerTwo_5">15</string>
    <string name="SectionNineTheoryPropsAnswerThree_5">16</string>
    <string name="SectionNineTheoryPropsCorrectAnswer_5">15</string>

    <string name="SectionNineTheoryWorkedExamples_5">Example 1: A number multiplied by 3 gives 18. Let x be the number. 3x=18 → x=6. \n
Example 2: Two numbers sum to 20, one is twice the other. Let x and 2x. x+2x=20 → x=20/3. ✗ (no integer solution — check problem). \n
Example 3: A train travels 120 km in 2 hours. Speed = 120/2 = 60 km/h. </string>
    <string name="SectionNineTheoryWorkedExQuestion_5">A number multiplied by 4 gives 36. What is the number?</string>
    <string name="SectionNineTheoryWorkedExAnswerOne_5">7</string>
    <string name="SectionNineTheoryWorkedExAnswerTwo_5">8</string>
    <string name="SectionNineTheoryWorkedExAnswerThree_5">9</string>
