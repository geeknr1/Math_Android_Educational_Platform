    <!--                  SECTION TWO: AREA FORMULAS                     -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <string name="SectionTwoTheoryDef_14">• Base: Any chosen side of a figure.
\n • Altitude: Perpendicular from opposite side or vertex to the base.
\n • Used to define areas of triangles and parallelograms.</string>

    <!-- Q: Is the altitude perpendicular to the base? Answer: True -->
    <string name="SectionTwoTheoryDefQuestion_14">Is the altitude of a triangle or parallelogram perpendicular to the base?</string>
    <string name="SectionTwoTheoryDefAnswerOne_14">True</string>
    <string name="SectionTwoTheoryDefAnswerTwo_14">False</string>
    <!-- Only 2 answers for True/False — third answer intentionally removed -->
    <string name="SectionTwoTheoryDefAnswerThree_14"></string>
    <string name="SectionTwoTheoryDefCorrectAnswer_14">True</string>

    <string name="SectionTwoTheoryProperties_14">• Rectangle area = base × altitude.
\n • Triangle area = ½ × base × altitude.
\n • Parallelogram area = base × altitude or a*b*sinα.
\n • Triangle area using sides and angle = ½ × b*c*sinα.
\n • Inscribed/circumscribed triangle area: S=pr or S=(a*b*c)/(4R).
\n • Herons formula: S=√(p(p−a)(p−b)(p−c)).
\n • Trapezoid area = ½ × sum of bases × altitude.</string>

    <!-- Q: A triangle has base 6 and altitude 4. What is its area? Answer: 12 -->
    <string name="SectionTwoTheoryPropsQuestion_14">A triangle has base 6 and altitude 4. What is its area?</string>
    <string name="SectionTwoTheoryPropsAnswerOne_14">24</string>
    <string name="SectionTwoTheoryPropsAnswerTwo_14">12</string>
    <string name="SectionTwoTheoryPropsAnswerThree_14">10</string>
    <string name="SectionTwoTheoryPropsCorrectAnswer_14">12</string>

    <string name="SectionTwoTheoryWorkedExamples_14">• Rectangle with base 8 and altitude 5: area = 8 × 5 = 40.
\n • Triangle with base 10 and altitude 6: area = ½ × 10 × 6 = 30.
\n • Trapezoid with parallel bases 4 and 8 and altitude 5: area = ½ × (4 + 8) × 5 = 30.</string>

    <!-- Q: A rectangle has base 8 and altitude 5. What is its area? Answer: 40 -->
    <string name="SectionTwoTheoryWorkedExQuestion_14">A rectangle has base 8 and altitude 5. What is its area?</string>
    <string name="SectionTwoTheoryWorkedExAnswerOne_14">13</string>
    <string name="SectionTwoTheoryWorkedExAnswerTwo_14">26</string>
    <string name="SectionTwoTheoryWorkedExAnswerThree_14">40</string>
    <string name="SectionTwoTheoryWorkedExCorrectAnswer_14">40</string>

