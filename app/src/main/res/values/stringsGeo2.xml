    <!--                        SECTION ONE: TRIANGLES                   -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <string name="SectionOneTheoryDef_9">• A triangle has three sides and angles.
\n • Includes vertices, sides, and special lines.
\n • Triangles differ by sides, angles, and congruence.</string>

    <string name="SectionOneTheoryDefQuestion_9">How many sides does a triangle have?</string>
    <string name="SectionOneTheoryDefAnswerOne_9">2</string>
    <string name="SectionOneTheoryDefAnswerTwo_9">3</string>
    <string name="SectionOneTheoryDefAnswerThree_9">4</string>
    <string name="SectionOneTheoryDefCorrectAnswer_9">3</string>

    <string name="SectionOneTheoryProperties_9">• Every triangle has bisectors, medians, and altitudes.
\n • Larger sides face larger angles.
\n • The exterior angle is greater than any interior one.</string>

    <string name="SectionOneTheoryPropsQuestion_9">Is the exterior angle of a triangle greater than any non-adjacent interior angle?</string>
    <string name="SectionOneTheoryPropsAnswerOne_9">True</string>
    <string name="SectionOneTheoryPropsAnswerTwo_9">False</string>
    <string name="SectionOneTheoryPropsAnswerThree_9"></string>
    <string name="SectionOneTheoryPropsCorrectAnswer_9">True</string>

    <string name="SectionOneTheoryWorkedExamples_9">• In triangle ABC, AB = AC (isosceles). Since base angles are equal, angle B = angle C.
\n • The median from A to BC is also the angle bisector and altitude, because the triangle is isosceles.
\n • From point P outside line l, exactly one perpendicular can be drawn to l — its length is the shortest distance from P to l.</string>

    <string name="SectionOneTheoryWorkedExQuestion_9">In an isosceles triangle, how many base angles are equal to each other?</string>
    <string name="SectionOneTheoryWorkedExAnswerOne_9">1</string>
    <string name="SectionOneTheoryWorkedExAnswerTwo_9">2</string>
    <string name="SectionOneTheoryWorkedExAnswerThree_9">3</string>
    <string name="SectionOneTheoryWorkedExCorrectAnswer_9">2</string>

