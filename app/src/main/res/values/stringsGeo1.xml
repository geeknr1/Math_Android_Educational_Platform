    <!-- ===================== SECTION TWO: Geometric Figures ===================== -->
    <string name="SectionTwoTheoryDef_8">• A segment joins two endpoints.
\n • A ray starts at one point and goes on endlessly.
\n • Angles, polygons, and circles are key geometric figures.</string>
    <string name="SectionTwoTheoryDefQuestion_8">What is the sum of angles in a triangle (in degrees)?</string>
    <string name="SectionTwoTheoryDefAnswerOne_8">90</string>
    <string name="SectionTwoTheoryDefAnswerTwo_8">180</string>
    <string name="SectionTwoTheoryDefAnswerThree_8">360</string>
    <string name="SectionTwoTheoryDefCorrectAnswer_8">180</string>

    <string name="SectionTwoTheoryProperties_8">• A line divides a plane into two parts.
\n • Vertical angles are equal.
\n • The sum of adjacent angles equals 180°.</string>
    <string name="SectionTwoTheoryPropsQuestion_8">If one angle in a pair of vertical angles is 65°, what is the other (in degrees)?</string>
    <string name="SectionTwoTheoryPropsAnswerOne_8">90</string>
    <string name="SectionTwoTheoryPropsAnswerTwo_8">65</string>
    <string name="SectionTwoTheoryPropsAnswerThree_8">115</string>
    <string name="SectionTwoTheoryPropsCorrectAnswer_8">65</string>

    <string name="SectionTwoTheoryWorkedExamples_8">• Example 1: Two adjacent angles are supplementary. If one is 70°, the other = 180° − 70° = 110°. ✓
\n • Example 2: Two vertical angles are formed at an intersection. If one is 45°, its vertical pair is also 45°. ✓
\n • Example 3: A triangle has angles 50° and 70°. Third angle = 180° − 50° − 70° = 60°. ✓</string>
    <string name="SectionTwoTheoryWorkedExQuestion_8">If two adjacent angles are supplementary and one is 120°, what is the other (in degrees)?</string>
    <string name="SectionTwoTheoryWorkedExAnswerOne_8">30</string>
    <string name="SectionTwoTheoryWorkedExAnswerTwo_8">60</string>
    <string name="SectionTwoTheoryWorkedExAnswerThree_8">90</string>
    <string name="SectionTwoTheoryWorkedExCorrectAnswer_8">60</string>

