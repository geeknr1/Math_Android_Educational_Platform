    <!-- ===================== SECTION ONE: Geometry – Basic Concepts ===================== -->
    <string name="SectionOneTheoryDef_8">• Geometry studies shapes and space.
\n • Points, lines, and planes are basic ideas.
\n • Figures are made of points and follow axioms and theorems.</string>
    <string name="SectionOneTheoryDefQuestion_8">How many lines pass through exactly two distinct points?</string>
    <string name="SectionOneTheoryDefAnswerOne_8">0</string>
    <string name="SectionOneTheoryDefAnswerTwo_8">1</string>
    <string name="SectionOneTheoryDefAnswerThree_8">∞</string>
    <string name="SectionOneTheoryDefCorrectAnswer_8">1</string>

    <string name="SectionOneTheoryProperties_8">• Through two points passes one line.
\n • Distance is always positive or zero.
\n • Triangle sides obey the triangle inequality.</string>
    <string name="SectionOneTheoryPropsQuestion_8">Is the distance between two distinct points always greater than 0?</string>
    <string name="SectionOneTheoryPropsAnswerOne_8">True</string>
    <string name="SectionOneTheoryPropsAnswerTwo_8">False</string>
    <string name="SectionOneTheoryPropsAnswerThree_8">Neither</string>
    <string name="SectionOneTheoryPropsCorrectAnswer_8">True</string>

    <string name="SectionOneTheoryWorkedExamples_8">• Proofs show how distances relate in triangles.
\n • Example: ∣AC∣≥∣AB∣−∣BC∣ and ∣AC∣&lt;∣AB∣+∣BC∣ for non-collinear points.
\n • Example: Given AB = 5 and BC = 3, verify AC &lt; 8 and AC &gt; 2. Both hold for any valid triangle.
\n • Example: Three collinear points A, B, C with AB = 4 and BC = 6 give AC = 10. ✓</string>
    <string name="SectionOneTheoryWorkedExQuestion_8">If AB = 6 and BC = 4, what is the maximum possible integer value of AC?</string>
    <string name="SectionOneTheoryWorkedExAnswerOne_8">8</string>
    <string name="SectionOneTheoryWorkedExAnswerTwo_8">9</string>
    <string name="SectionOneTheoryWorkedExAnswerThree_8">10</string>
    <string name="SectionOneTheoryWorkedExCorrectAnswer_8">9</string>

