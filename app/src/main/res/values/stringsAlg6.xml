    <!-- ===================== SECTION TWO: Properties of Functions ===================== -->
    <string name="SectionTwoTheoryDef_6">Even: f(-x)=f(x). Odd: f(-x)=-f(x). Monotone: increasing or decreasing. Constant sign: f(x)&gt;0 or &lt;0. Roots: f(x)=0.</string>
    <string name="SectionTwoTheoryDefQuestion_6">Is f(x) = x² an even function?</string>
    <string name="SectionTwoTheoryDefAnswerOne_6">True</string>
    <string name="SectionTwoTheoryDefAnswerTwo_6">False</string>
    <string name="SectionTwoTheoryDefAnswerThree_6">Neither</string>
    <string name="SectionTwoTheoryDefCorrectAnswer_6">True</string>

    <string name="SectionTwoTheoryProperties_6">Even → y-axis symmetry; Odd → origin symmetry. Increasing rises, decreasing falls. Roots at x-axis intersections.</string>
    <string name="SectionTwoTheoryPropsQuestion_6">Does an odd function have origin symmetry?</string>
    <string name="SectionTwoTheoryPropsAnswerOne_6">True</string>
    <string name="SectionTwoTheoryPropsAnswerTwo_6">False</string>
    <string name="SectionTwoTheoryPropsAnswerThree_6">Neither</string>
    <string name="SectionTwoTheoryPropsCorrectAnswer_6">True</string>

    <string name="SectionTwoTheoryWorkedExamples_6">Example 1: f(x) = x³. Check oddness: f(−x) = (−x)³ = −x³ = −f(x). Odd function. ✓
Example 2: f(x) = x² + 1. Check evenness: f(−x) = (−x)² + 1 = x² + 1 = f(x). Even function. ✓
Example 3: f(x) = x + 1. f(−x) = −x + 1. Neither f(x) nor −f(x). Neither even nor odd. ✓</string>
    <string name="SectionTwoTheoryWorkedExQuestion_6">Is f(x) = x³ an odd function?</string>
    <string name="SectionTwoTheoryWorkedExAnswerOne_6">True</string>
    <string name="SectionTwoTheoryWorkedExAnswerTwo_6">False</string>
    <string name="SectionTwoTheoryWorkedExAnswerThree_6">Neither</string>
    <string name="SectionTwoTheoryWorkedExCorrectAnswer_6">True</string>

