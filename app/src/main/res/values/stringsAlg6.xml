    <!-- ===================== SECTION FOUR: Basic Function Types and Their Graphs ===================== -->
    <string name="SectionFourTheoryDef_6">Basic: Linear y=kx+b, Inverse y=k/x, Quadratic y=ax²+bx+c, Power y=xⁿ, Logarithmic y=logₐx. Shapes: line, hyperbola, parabola.</string>
    <string name="SectionFourTheoryDefQuestion_6">What is the shape of the graph of y = k/x (k ≠ 0)?</string>
    <string name="SectionFourTheoryDefAnswerOne_6">line</string>
    <string name="SectionFourTheoryDefAnswerTwo_6">parabola</string>
    <string name="SectionFourTheoryDefAnswerThree_6">hyperbola</string>
    <string name="SectionFourTheoryDefCorrectAnswer_6">hyperbola</string>

    <string name="SectionFourTheoryProperties_6">|f(x)| reflects negative part over x-axis. Linear/quadratic shape from coefficients. Hyperbola position → sign of k. Parabola opens up (a&gt;0) or down (a&lt;0).</string>
    <string name="SectionFourTheoryPropsQuestion_6">If a &gt; 0 in y = ax² + bx + c, does the parabola open upward?</string>
    <string name="SectionFourTheoryPropsAnswerOne_6">True</string>
    <string name="SectionFourTheoryPropsAnswerTwo_6">False</string>
    <string name="SectionFourTheoryPropsAnswerThree_6">Neither</string>
    <string name="SectionFourTheoryPropsCorrectAnswer_6">True</string>

    <string name="SectionFourTheoryWorkedExamples_6">Example 1: y = 2x + 3. Linear function. Slope = 2, y-intercept = 3. Graph is a straight line rising left to right. ✓
Example 2: y = x². Quadratic. Vertex at (0,0). Opens upward (a=1&gt;0). ✓
Example 3: y = 1/x. Hyperbola in quadrants 1 and 3 (k=1&gt;0). Defined for all x ≠ 0. ✓</string>
    <string name="SectionFourTheoryWorkedExQuestion_6">For y = −x², does the parabola open upward or downward? Enter 1 for upward, -1 for downward.</string>
    <string name="SectionFourTheoryWorkedExAnswerOne_6">1</string>
    <string name="SectionFourTheoryWorkedExAnswerTwo_6">-1</string>
    <string name="SectionFourTheoryWorkedExAnswerThree_6">0</string>
    <string name="SectionFourTheoryWorkedExCorrectAnswer_6">-1</string>

