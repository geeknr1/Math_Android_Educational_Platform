    <!-- ===================== SECTION ONE: Function – Definition ===================== -->
    <string name="SectionOneTheoryDef_6">Function: assigns each x in domain to one y. x–independent, y–dependent. Forms: analytic, tabular, graphical. Notation: y=f(x).</string>
    <string name="SectionOneTheoryDefQuestion_6">If f(x) = 2x + 1, what is f(3)?</string>
    <string name="SectionOneTheoryDefAnswerOne_6">5</string>
    <string name="SectionOneTheoryDefAnswerTwo_6">7</string>
    <string name="SectionOneTheoryDefAnswerThree_6">9</string>
    <string name="SectionOneTheoryDefCorrectAnswer_6">7</string>

    <string name="SectionOneTheoryProperties_6">Analytic: formula; Tabular: values; Graphical: plot points. Domain → x, Range → y. Used for calc, observation, visualization.</string>
    <string name="SectionOneTheoryPropsQuestion_6">What is the range value of f(x) = x² when x = 4?</string>
    <string name="SectionOneTheoryPropsAnswerOne_6">8</string>
    <string name="SectionOneTheoryPropsAnswerTwo_6">16</string>
    <string name="SectionOneTheoryPropsAnswerThree_6">12</string>
    <string name="SectionOneTheoryPropsCorrectAnswer_6">16</string>

    <string name="SectionOneTheoryWorkedExamples_6">Example 1: f(x) = 3x − 2. Find f(4). Substitute: f(4) = 3·4 − 2 = 10. ✓
Example 2: f(x) = x². Domain: all real numbers. Range: y ≥ 0. ✓
Example 3: g(x) = 1/x. Domain: all x ≠ 0. Find g(5) = 1/5. ✓</string>
    <string name="SectionOneTheoryWorkedExQuestion_6">If f(x) = x² − 1, what is f(0)?</string>
    <string name="SectionOneTheoryWorkedExAnswerOne_6">-1</string>
    <string name="SectionOneTheoryWorkedExAnswerTwo_6">0</string>
    <string name="SectionOneTheoryWorkedExAnswerThree_6">1</string>
    <string name="SectionOneTheoryWorkedExCorrectAnswer_6">-1</string>

