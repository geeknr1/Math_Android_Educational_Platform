    <!--               SECTION TWO: ARCS & INSCRIBED ANGLES             -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <string name="SectionTwoTheoryDef_10">• An arc is part of a circle.
\n • A central angle has its vertex at the center.
\n • An inscribed angle has its vertex on the circle.</string>

    <!-- Q: Where is the vertex of an inscribed angle? Answer: on the circle -->
    <string name="SectionTwoTheoryDefQuestion_10">Where is the vertex of an inscribed angle located?</string>
    <string name="SectionTwoTheoryDefAnswerOne_10">on the circle</string>
    <string name="SectionTwoTheoryDefAnswerTwo_10">at the center</string>
    <string name="SectionTwoTheoryDefAnswerThree_10">outside the circle</string>
    <string name="SectionTwoTheoryDefCorrectAnswer_10">on the circle</string>

    <string name="SectionTwoTheoryProperties_10">• Arc measure equals its central angle.
\n • Inscribed angle equals half the central one.
\n • Angles on the same arc are equal; semicircle gives 90°.</string>

    <!-- Q: An inscribed angle equals what fraction of its intercepted central angle? Answer: 1/2 -->
    <string name="SectionTwoTheoryPropsQuestion_10">An inscribed angle is equal to what fraction of its intercepted central angle?</string>
    <string name="SectionTwoTheoryPropsAnswerOne_10">1/4</string>
    <string name="SectionTwoTheoryPropsAnswerTwo_10">1/2</string>
    <string name="SectionTwoTheoryPropsAnswerThree_10">2</string>
    <string name="SectionTwoTheoryPropsCorrectAnswer_10">1/2</string>

    <string name="SectionTwoTheoryWorkedExamples_10">• Case 1 (diameter as one side): The central angle is twice the inscribed angle by the isosceles triangle formed with two radii — the base angles are equal, and the exterior angle equals their sum.
\n • Case 2 (center inside the angle): Split the inscribed angle into two sub-angles each containing the diameter as one side; apply Case 1 to each and add the results.
\n • Case 3 (center outside the angle): Subtract the smaller Case-1 result from the larger — the inscribed angle still equals half the central angle, confirming the theorem for all configurations.</string>

    <!-- Q: An inscribed angle in a semicircle equals how many degrees? Answer: 90 -->
    <string name="SectionTwoTheoryWorkedExQuestion_10">An inscribed angle that intercepts a semicircle equals how many degrees?</string>
    <string name="SectionTwoTheoryWorkedExAnswerOne_10">45</string>
    <string name="SectionTwoTheoryWorkedExAnswerTwo_10">180</string>
    <string name="SectionTwoTheoryWorkedExAnswerThree_10">90</string>
    <string name="SectionTwoTheoryWorkedExCorrectAnswer_10">90</string>

