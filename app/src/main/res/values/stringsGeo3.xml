    <!--                  SECTION ONE: TANGENTS & CIRCLES                -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <string name="SectionOneTheoryDef_10">• A tangent touches a circle at one point.
\n • Circles may touch or intersect.
\n • Concentric circles share the same center.</string>

    <!-- Q: How many points does a tangent touch a circle at? Answer: 1 -->
    <string name="SectionOneTheoryDefQuestion_10">At how many points does a tangent touch a circle?</string>
    <string name="SectionOneTheoryDefAnswerOne_10">1</string>
    <string name="SectionOneTheoryDefAnswerTwo_10">2</string>
    <string name="SectionOneTheoryDefAnswerThree_10">3</string>
    <string name="SectionOneTheoryDefCorrectAnswer_10">1</string>

    <string name="SectionOneTheoryProperties_10">• If R&gt;d, line cuts circle; if R=d, it\'s tangent.
\n • A tangent is perpendicular to the radius.
\n • Tangent segments from one point are equal.</string>

    <!-- Q: Is a tangent perpendicular to the radius at the point of tangency? Answer: True -->
    <string name="SectionOneTheoryPropsQuestion_10">Is a tangent to a circle perpendicular to the radius at the point of tangency?</string>
    <string name="SectionOneTheoryPropsAnswerOne_10">True</string>
    <string name="SectionOneTheoryPropsAnswerTwo_10">False</string>
    <!-- Only 2 answers for True/False — third answer intentionally removed -->
    <string name="SectionOneTheoryPropsAnswerThree_10"></string>
    <string name="SectionOneTheoryPropsCorrectAnswer_10">True</string>

    <string name="SectionOneTheoryWorkedExamples_10">• To find a tangent to circle O parallel to line l: drop a perpendicular from O to l, extend it to meet the circle — the two intersection points are the tangency points of the two parallel tangents.
\n • To find a common external tangent to two circles: construct an auxiliary circle with radius equal to the difference of the two radii, find a tangent from the external center, then translate it to both original circles.
\n • In both cases the key step is identifying the foot of the perpendicular from the center, which fixes the tangency point uniquely.</string>

    <!-- Q: How many tangent segments drawn from an external point to a circle are equal? Answer: 2 -->
    <string name="SectionOneTheoryWorkedExQuestion_10">How many equal tangent segments can be drawn from a single external point to a circle?</string>
    <string name="SectionOneTheoryWorkedExAnswerOne_10">1</string>
    <string name="SectionOneTheoryWorkedExAnswerTwo_10">2</string>
    <string name="SectionOneTheoryWorkedExAnswerThree_10">3</string>
    <string name="SectionOneTheoryWorkedExCorrectAnswer_10">2</string>

